  <Transformation>
    <Fields>
              <Array Alias="TRANSACTIONTD01" DataField="TRANSACTIONTD01" Flat="true">
				<Fields>
					<String Alias="TransactionAmount" DataField="AuthorizationAmount" >
						<Actions>
							<CSharp Order="-1"  >
								<Code>
									if(!string.IsNullOrEmpty(V)){
										double dText = 0;
										bool bText = Double.TryParse(V, out dText);
										dText = dText / 100;
										return string.Format("{0:0.00}", (dText));
									}
									return V;
								</Code>
							</CSharp>
						</Actions>
					</String>
					<String Alias="AuthorizationAmount" DataField="AuthorizationAmount" >
						<Actions>
							<CSharp Order="-1"  >
								<Code>
									if(!string.IsNullOrEmpty(V)){
										double dText = 0;
										bool bText = Double.TryParse(V, out dText);
										dText = dText / 100;
										return string.Format("{0:0.00}", (dText));
									}
									return V;
								</Code>
							</CSharp>
						</Actions>
					</String>

					<String Alias="POSEntryMode">
						<Actions>
							<CSharp Order="-1">
								<Code>
									R.TryGetValue("PointOfSale", out IExtractedInfo info);
									string PointOfSale = info == null ? null : R.Block.GetValue(info);
									R.TryGetValue("PointOfSaleCap", out IExtractedInfo info1);
									string PointOfSaleCap = info1 == null ? null : R.Block.GetValue(info1);
									
									return PointOfSale+PointOfSaleCap;
								</Code>
							</CSharp>
						</Actions>
					</String>
					
					<String Alias="ChipConditionCode" DataField="AdditionalPOSInfor" >
						<Actions>
							<SubString Order="1"  StartOffset="2" EndOffset="1" />
						</Actions>
					</String>
					<String Alias="MOTO" DataField="AdditionalPOSInfor" >
						<Actions>
							<SubString Order="1"  StartOffset="8" EndOffset="2" />
						</Actions>
					</String>
					
					<String Alias="AccountNumber" DataField="AccountNumber" >
						<Actions>
							<CSharp Order="0">
								<Code>
									return V == null ? null : V.Replace("xxxxxxxxx","999999");
								</Code>
							</CSharp>
						</Actions>
					</String>
					<Encrypt Alias="AccountNumber" DataField="AccountNumber">
						<Actions>
							<CSharp Order="-2">
								<Code>
									return !string.IsNullOrEmpty(V) ? V : "";
								</Code>
							</CSharp>
						</Actions>
					</Encrypt>
					<Encrypt Alias="EncryptedAccountNumber" DataField="AccountNumber"/>
					<Hash Alias="HashedAccountNumber" DataField="AccountNumber"/>
					<Hash Alias="HashedBin8" DataField="AccountNumber">
						<Actions>
							<SubString Order="0" StartOffset="0" EndOffset="8" />
						</Actions>
					</Hash>
					<String Alias="BINNumber" DataField="AccountNumber" >
						<Actions>
							<CSharp Order="2">
								<Code>
									return string.IsNullOrEmpty(V) ? V : V.Substring(0, 6).Trim();
								</Code>
							</CSharp>
						</Actions>
					</String>
					<String Alias="MSAccountNumber" DataField="AccountNumber" >
						<Actions>
							<CSharp Order="2">
								<Code>
									return string.IsNullOrEmpty(V) ? V : V.Substring(V.Length - 4, 4).Trim();
								</Code>
							</CSharp>
						</Actions>
					</String>
					
					<String Alias="MerchantNumber" DataField="MerchantNumber">
						<Actions>
							<CheckPattern Order="-1" Pattern="(^$)|(^\d+$)" />
							<CSharp Order="-2">
								<Code>
									if (string.IsNullOrEmpty(V.Trim())) {
										return string.Empty;
									}

									while (V.StartsWith("0"))
									{
										V = V.Substring(1);
									}
									return V.Trim();
								</Code>
							</CSharp>
						</Actions>
					</String>
					
					<String Alias="TransactionDate" DataField="TransactionDate">
						<Actions>
							<CSharp Order="-1">
								<Code>
									V = V.Replace("-", "").Trim();
									return V.Substring(4, 2) + "/" + V.Substring(6, 2) + "/" + V.Substring(0, 4);
								</Code>
							</CSharp>
						</Actions>
					</String>
					<String Alias="TransactionTime" DataField="TransactionTime">
						<Actions>
							<CSharp Order="0">
								<Code>
									V = V.Replace(":", "").Trim();
									return V.Substring(0, 2) + ":" + V.Substring(2, 2) + ":" + V.Substring(4, 2);
								</Code>
							</CSharp>
						</Actions>
					</String>
					<String Alias="ExpirationDate" DataField="ExpirationDate">
						<Actions>
							<CSharp Order="0">
								<Code>
									V = V.Trim();
									return !string.IsNullOrEmpty(V) ? V.Substring(0, 2) + "/" + V.Substring(2, 2) : V;
								</Code>
							</CSharp>
						</Actions>
					</String>
					
					<String Alias="CardholderIDMethod" DataField="AdditionalPOSInfor">
						<Actions>
							<SubString Order="1"  StartOffset="10" EndOffset="1" />
						</Actions>
					</String>

					<Array Alias="TRANSACTIONTD11" DataField="TRANSACTIONTD11" Flat="true">
						<Fields>
							<Array Alias="EX02" DataField="EX02" Flat="true">
							</Array>
						</Fields>
					</Array>
				</Fields>
              </Array>
    </Fields>
    <Massage GlobalVariables="int _recordId;">
      <Code>var newB = new List&lt;IDictionary&lt;string, object&gt;&gt;(B.Count);
                            foreach (var record in B)
                            {
                                record["RecordID"] = ++_recordId;
                                record["FileSource"] = "FULTON_TSYS_AUTH";
								record["ReportDate"] = "";
								record["ReportTime"] = "";
								record["BankID"] = "VITAL";
                                newB.Add(record);
								<!-- } -->

                            }
                            return newB;
      </Code>
    </Massage>
  </Transformation>
