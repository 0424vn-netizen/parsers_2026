    <Massage GlobalVariables="int _recordId;">
      <Code>var newB = new List&lt;IDictionary&lt;string, object&gt;&gt;(B.Count);
                            foreach (var record in B)
                            {
                                record["RecordID"] = ++_recordId;
                                record["FileSource"] = "SupMIF";
								if (record["MerchantNumber"].ToString().Contains("Merchant") || record["MerchantNumber"].ToString().Contains("FT"))
								continue;
                                newB.Add(record);

                            }
                            return newB;
      </Code>
    </Massage>
