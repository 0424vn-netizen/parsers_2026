  <Transformation>  
	<Fields>	  
		<String Alias="MerchantNumber" DataField="MerchantNumber">
			<Actions>
				<CheckPattern Order="-1" Pattern="(^\d+$)" />
				<CSharp Order="-2">
					<Code>
						return !string.IsNullOrEmpty(V) ? V : "";
					</Code>
				</CSharp>
			</Actions>
		</String>
		
		<String Alias="RootID" DataField="RootID">
			<Actions>
			  <CSharp Order="-1">
				<Code>				  
				  return !string.IsNullOrEmpty(V) ? V.Trim('-') : "";
				</Code>
			  </CSharp>
			</Actions>
		</String>
		<String Alias="RootAgent" DataField="RootAgent">
