<?xml version="1.0" encoding="utf-8"?>
<Etl xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <!--
    WorldPay Dispute Management System - CHARTS File Parser
    Spec: WorldPay CHARTS mapping file_v1_April2026.xlsx

    File structure:
      MHFH  - File Header (1 line)
      MHCH  - Merchant Control Header (1 line)
      MHCB  - Merchant Detail Draft Record (N lines, 320 chars each, fixed-width)
      MHCT  - Control Trailer
      MHFT  - File Trailer

    All positions are 1-indexed inclusive, including the 4-space line prefix.
    Parser targets only MHCB records. Each MHCB line = one output row before merge.
    Massage groups by RecordNumber and merges Segment 2/3/4/5 into Segment 1.

    Multi-segment merge is handled in Massage using GlobalVariables (class-level
    fields that persist across all batch calls on the same instance). Records are
    accumulated until all TotalSegments have arrived — safe for any file size and
    any BatchSize, including across parallel-ordering resequencing.
  -->

  <Extraction>
    <!--
      Layout.Start / Layout.End are used by the Scanner to identify record boundaries.
      Each MHCB line is treated as a single-line record.
      Column direction children extract fixed-width fields by cursor offset.

      Cursor arithmetic (0-indexed):
        StartOffset = columns to advance from current cursor before reading
        EndOffset   = field length in characters
    -->
    <Layout Direction="Column" Start="^\s{4}MHCB" End="^\s{4}MHCB">

      <!-- Spec 13-18 (0-idx 12): DateReceived YYMMDD
           StartOffset=12 skips: 4 spaces + MHCB (4) + SortInstitutionId VNTV (4) = 12 -->
      <Layout DataField="DateReceived"                 StartOffset="12" EndOffset="6"  />

      <!-- Spec 19-20 (0-idx 18): TransactionType / DebitOrCredit
           40=Retrieval Request, 41=Chargeback, 42=Chargeback Reversal -->
      <Layout DataField="DebitOrCredit"                StartOffset="0"  EndOffset="2"  />

      <!-- Spec 21-30 (0-idx 20): DisputeAmount (10 digits, implied 2 decimal places) -->
      <Layout DataField="TransactionAmount"            StartOffset="0"  EndOffset="10" />

      <!-- Spec 31-42 (0-idx 30): RecordNumber (12 chars) -->
      <Layout DataField="RecordNumber"                 StartOffset="0"  EndOffset="12" />

      <!-- Spec 43 (0-idx 42): SegmentNumber (1=primary, 2=accounting detail) -->
      <Layout DataField="SegmentNumber"                StartOffset="0"  EndOffset="1"  />

      <!-- Spec 44 (0-idx 43): TotalSegments -->
      <Layout DataField="TotalSegments"                StartOffset="0"  EndOffset="1"  />

      <!-- Skip AcquirerTerminalId (45-52) + RegisterNumber (53-56) = 12 chars -->
      <Layout                                          StartOffset="0"  EndOffset="12" />

      <!-- Spec 57-60 (0-idx 56): NetworkID / CardTypeCode: DISC, VISA, M/C, AMEX -->
      <Layout DataField="CardTypeCode"                 StartOffset="0"  EndOffset="4"  />

      <!-- Skip MerchantDraftRetrievalNumber (61-71) + Reserved (72-73) = 13 chars -->
      <Layout                                          StartOffset="0"  EndOffset="13" />

      <!-- Spec 74 (0-idx 73): ChargebackUsageCode (presentation number: 1,2,3...) -->
      <Layout DataField="ChargebackUsageCode"          StartOffset="0"  EndOffset="1"  />

      <!-- Spec 75-78 (0-idx 74): AdjustmentType / ChargebackType
           DRFT=Retrieval, PNOT=Pre-notification, CHBK=Chargeback,
           REPR=Re-Presentment, PARB=Pre-Arbitration, ARBT=Arbitration,
           COMP=Compliance, FEE=Fee -->
      <Layout DataField="ChargebackType"               StartOffset="0"  EndOffset="4"  />

      <!-- Spec 79-84 (0-idx 78): OriginalTransDate YYMMDD -->
      <Layout DataField="TransactionDate"              StartOffset="0"  EndOffset="6"  />

      <!-- Skip Reserved (85-92) = 8 chars -->
      <Layout                                          StartOffset="0"  EndOffset="8"  />

      <!-- Spec 93-98 (0-idx 92): OriginalTransTime HHMMSS -->
      <Layout DataField="TransactionTime"              StartOffset="0"  EndOffset="6"  />

      <!-- Spec 99-117 (0-idx 98): PAN (19 chars, may have trailing spaces) -->
      <Layout DataField="PAN"                          StartOffset="0"  EndOffset="19" />

      <!-- Spec 118-121 (0-idx 117): ChargebackActionCode (MACP, CRMR, CHGM, etc.) -->
      <Layout DataField="ChargebackActionCode"         StartOffset="0"  EndOffset="4"  />

      <!-- Spec 122-127 (0-idx 121): ChargebackActionCodeDate / CentralProcessingDate YYMMDD -->
      <Layout DataField="CentralProcessingDate"        StartOffset="0"  EndOffset="6"  />

      <!-- Skip DepartmentNumber (128-132) + IssuerCurrencyCode (133-135) = 8 chars -->
      <Layout                                          StartOffset="0"  EndOffset="8"  />

      <!-- Spec 136-139 (0-idx 135): MCC -->
      <Layout DataField="MCC"                          StartOffset="0"  EndOffset="4"  />

      <!-- Spec 140-146 (0-idx 139): AdjustmentReasonCode / ReasonCode (7 chars)
           Prefixed by card type: V=Visa, M=Mastercard, D=Discover, A=Amex -->
      <Layout DataField="ReasonCode"                   StartOffset="0"  EndOffset="7"  />

      <!-- Spec 147-158 (0-idx 146): ChargebackReferenceNumber / CBReferenceNumber (12 chars) -->
      <Layout DataField="CBReferenceNumber"            StartOffset="0"  EndOffset="12" />

      <!-- Spec 159-161 (0-idx 158): TransactionDispositionQualifier
           100=New Item, 101=Delete, 102=Update -->
      <Layout DataField="TransactionDispositionQualifier" StartOffset="0" EndOffset="3" />

      <!-- Spec 162-184 (0-idx 161): AcquirerReferenceNumber / ReferenceNumber (23 chars) -->
      <Layout DataField="ReferenceNumber"              StartOffset="0"  EndOffset="23" />

      <!-- Spec 185-189 (0-idx 184): MerchantChain (5 chars) -->
      <Layout DataField="MerchantChain"                StartOffset="0"  EndOffset="5"  />

      <!-- Spec 190-192 (0-idx 189): DivisionNumber (3 chars) -->
      <Layout DataField="DivisionNumber"               StartOffset="0"  EndOffset="3"  />

      <!-- Spec 193-201 (0-idx 192): MerchantStoreNumber (9 chars) -->
      <Layout DataField="MerchantStoreNumber"          StartOffset="0"  EndOffset="9"  />

      <!-- Spec 202-204 (0-idx 201): FeeAmount (3 chars, implied decimal, used when ChargebackType=FEE) -->
      <Layout DataField="Fee"                          StartOffset="0"  EndOffset="3"  />

      <!-- Skip SalesPersonNumber (205-213) = 9 chars -->
      <Layout                                          StartOffset="0"  EndOffset="9"  />

      <!-- Spec 214-215 (0-idx 213): EntryMode (Visa only)
           00=Not used, 01=Keyed, 02=MagStripe, 90=MagStripe PS2000 -->
      <Layout DataField="EntryMode"                    StartOffset="0"  EndOffset="2"  />

      <!-- Skip AuthSource(216) + Reserved(217) = 2 chars -->
      <Layout                                          StartOffset="0"  EndOffset="2"  />

      <!-- Spec 218 (0-idx 217): ECI - Electronic Commerce Indicator (1 char) -->
      <Layout DataField="ECI"                          StartOffset="0"  EndOffset="1"  />

      <!-- Skip ThirdPartyFlag(219) = 1 char -->
      <Layout                                          StartOffset="0"  EndOffset="1"  />

      <!-- Spec 220-269 (0-idx 219): CommentsFromIssuer (50 chars) -->
      <Layout DataField="CommentsFromIssuer"           StartOffset="0"  EndOffset="50" />

      <!-- Skip Filler(270-303) = 34 chars -->
      <Layout                                          StartOffset="0"  EndOffset="34" />

      <!-- Spec 304-319 (0-idx 303): MerchantIdentificationNumber / MerchantNumber (16 chars) -->
      <Layout DataField="MerchantNumber"               StartOffset="0"  EndOffset="16" />

      <!--
        Segment 2 unique fields — extracted from ALL MHCB lines but only used for SegmentNumber=2.
        Byte ranges REUSE positions that Segment 1 uses for different fields.
        Cursor is at 319 after MerchantNumber; use negative StartOffset to jump back.

        Seg-2 field layout (1-indexed):
          User Note              131-170  (40 chars): 0-idx [130:170]
          Comment to Merchant    171-232  (62 chars): 0-idx [170:232]
          (Chain/Div/Store       233-249 = 17 chars, skip)
          (Gap                   250-258 = 9 chars,  skip)
          Comment From Merchant  259-320  (62 chars): 0-idx [258:320]
      -->

      <!-- Jump back: 130 - 319 = -189; User Note [130:170] = 40 chars -->
      <Layout DataField="Seg2UserNote"           StartOffset="-189" EndOffset="40"  />

      <!-- Comment to Merchant [170:232] = 62 chars; cursor now 170 -->
      <Layout DataField="Seg2CommentToMerchant"  StartOffset="0"    EndOffset="62"  />

      <!-- Skip Chain+Div+Store+padding [232:258] = 26 chars; cursor now 232 -->
      <Layout                                    StartOffset="0"    EndOffset="26"  />

      <!-- Comment From Merchant [258:320] = 62 chars; cursor now 258 -->
      <Layout DataField="Seg2CommentFromMerchant" StartOffset="0"   EndOffset="62"  />

      <!--
        Segment 3&4 unique field — Merchant Research Comments Line 81-320 (240 chars): 0-idx [80:320]
        Cursor is at 320; jump back: 80 - 320 = -240
        Both Segment 3 and Segment 4 share this same layout per spec.
        If a record has both Seg-3 and Seg-4, Massage concatenates them.
      -->
      <Layout DataField="Seg3ResearchComments"   StartOffset="-240" EndOffset="240" />

      <!--
        Segment 5 unique fields (spec "Segment 5 Position"):
          Discretionary Field 1   81-115  (35 chars): 0-idx [80:115]
          Discretionary Field 2  116-135  (20 chars): 0-idx [115:135]
          Discretionary Field 3  136-155  (20 chars): 0-idx [135:155]
          (skip MerchantNumber+gap 156-217 = 62 chars)
          Amazon Pay Charge ID   218-244  (27 chars): 0-idx [217:244]
          PAR                    245-279  (35 chars): 0-idx [244:279]
        Cursor is at 320; jump back: 80 - 320 = -240
      -->
      <Layout DataField="Seg5DiscretionaryField1"  StartOffset="-240" EndOffset="35"  />
      <Layout DataField="Seg5DiscretionaryField2"  StartOffset="0"    EndOffset="20"  />
      <Layout DataField="Seg5DiscretionaryField3"  StartOffset="0"    EndOffset="20"  />
      <!-- Skip MerchantNumber(156-171) + gap(172-217) = 62 chars; cursor 155 -->
      <Layout                                      StartOffset="0"    EndOffset="62"  />
      <Layout DataField="Seg5AmazonPayChargeId"    StartOffset="0"    EndOffset="27"  />
      <Layout DataField="Seg5PAR"                  StartOffset="0"    EndOffset="35"  />

    </Layout>
  </Extraction>

  <Transformation>
    <Fields>

      <!-- DateReceived: YYMMDD -> YYYY/MM/DD
           Year pivot: yy < 70 => 20xx, else 19xx -->
      <String Alias="DateReceived" DataField="DateReceived">
        <Actions>
          <CSharp Order="-1">
            <Code>
              if (string.IsNullOrWhiteSpace(V) || V.Trim().Length != 6) return null;
              var d = V.Trim();
              var yy = int.Parse(d.Substring(0, 2));
              var yyyy = (yy &lt; 70 ? "20" : "19") + d.Substring(0, 2);
              return yyyy + "/" + d.Substring(2, 2) + "/" + d.Substring(4, 2);
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- DebitOrCredit: 40=Retrieval, 41=Chargeback of Purchase, 42=Reversal/Refund CB -->
      <String Alias="DebitOrCredit" DataField="DebitOrCredit">
        <Actions>
          <CSharp Order="-1">
            <Code>return V?.Trim();</Code>
          </CSharp>
        </Actions>
      </String>

      <!-- Reversal: "Reversal" when DebitOrCredit=42, null otherwise -->
      <String Alias="Reversal" DataField="DebitOrCredit">
        <Actions>
          <CSharp Order="-1">
            <Code>return "42".Equals(V?.Trim()) ? "Reversal" : null;</Code>
          </CSharp>
        </Actions>
      </String>

      <!-- TransactionAmount: 10-digit implied 2-decimal (e.g. 0000064772 = 647.72) -->
      <String Alias="TransactionAmount" DataField="TransactionAmount">
        <Actions>
          <CSharp Order="-1">
            <Code>
              var s = V?.Trim();
              if (string.IsNullOrEmpty(s)) return null;
              if (long.TryParse(s, out long val))
                return (val / 100.0).ToString("F2");
              return s;
            </Code>
          </CSharp>
        </Actions>
      </String>

      <String Alias="RecordNumber" DataField="RecordNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <String Alias="SegmentNumber" DataField="SegmentNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <String Alias="TotalSegments" DataField="TotalSegments">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- CardTypeCode: DISC, VISA, M/C, AMEX -->
      <String Alias="CardTypeCode" DataField="CardTypeCode">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- ChargebackUsageCode: presentation number (1=first, 2=second, ...) -->
      <String Alias="ChargebackUsageCode" DataField="ChargebackUsageCode">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- ChargebackType: DRFT, PNOT, CHBK, REPR, PARB, ARBT, COMP, FEE -->
      <String Alias="ChargebackType" DataField="ChargebackType">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- TransactionDate: YYMMDD -> YYYY/MM/DD (original transaction date) -->
      <String Alias="TransactionDate" DataField="TransactionDate">
        <Actions>
          <CSharp Order="-1">
            <Code>
              if (string.IsNullOrWhiteSpace(V)) return null;
              var d = V.Trim();
              if (d.Length != 6) return null;
              var yy = int.Parse(d.Substring(0, 2));
              var yyyy = (yy &lt; 70 ? "20" : "19") + d.Substring(0, 2);
              return yyyy + "/" + d.Substring(2, 2) + "/" + d.Substring(4, 2);
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- TransactionTime: HHMMSS -> HH:MM:SS (original transaction time) -->
      <String Alias="TransactionTime" DataField="TransactionTime">
        <Actions>
          <CSharp Order="-1">
            <Code>
              if (string.IsNullOrWhiteSpace(V)) return null;
              var t = V.Trim();
              if (t.Length != 6) return null;
              return t.Substring(0, 2) + ":" + t.Substring(2, 2) + ":" + t.Substring(4, 2);
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- HashedAccountNumber: PAN hashed with salt (uses configured salt key) -->
      <Hash Alias="HashedAccountNumber" DataField="PAN">
        <Actions>
          <CSharp Order="-1">
            <Code>return V?.Trim();</Code>
          </CSharp>
        </Actions>
      </Hash>

      <!-- BinNumber: first 6 digits of PAN -->
      <String Alias="BinNumber" DataField="PAN">
        <Actions>
          <CSharp Order="-1">
            <Code>
              var pan = V?.Trim();
              if (string.IsNullOrEmpty(pan)) return null;
              return pan.Length >= 6 ? pan.Substring(0, 6) : pan;
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- MSAccountNumber: last 4 digits of PAN -->
      <String Alias="MSAccountNumber" DataField="PAN">
        <Actions>
          <CSharp Order="-1">
            <Code>
              var pan = V?.Trim();
              if (string.IsNullOrEmpty(pan)) return null;
              return pan.Length >= 4 ? pan.Substring(pan.Length - 4) : pan;
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- ChargebackActionCode: MACP=Mastercard Accept, CHGM=Charge to Merchant, etc. -->
      <String Alias="ChargebackActionCode" DataField="ChargebackActionCode">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- CentralProcessingDate: YYMMDD -> YYYY/MM/DD (date chargeback action was taken) -->
      <String Alias="CentralProcessingDate" DataField="CentralProcessingDate">
        <Actions>
          <CSharp Order="-1">
            <Code>
              if (string.IsNullOrWhiteSpace(V)) return null;
              var d = V.Trim();
              if (d.Length != 6) return null;
              var yy = int.Parse(d.Substring(0, 2));
              var yyyy = (yy &lt; 70 ? "20" : "19") + d.Substring(0, 2);
              return yyyy + "/" + d.Substring(2, 2) + "/" + d.Substring(4, 2);
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- MCC: Merchant Category Code -->
      <String Alias="MCC" DataField="MCC">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- ReasonCode: card-type-prefixed reason (e.g. D4753, V1004, M4853, AF30) -->
      <String Alias="ReasonCode" DataField="ReasonCode">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- CBReferenceNumber: case/control number from the card network -->
      <String Alias="CBReferenceNumber" DataField="CBReferenceNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- FirstTime: "Yes" when TransactionDispositionQualifier=100 (New Item), "No" otherwise -->
      <String Alias="FirstTime" DataField="TransactionDispositionQualifier">
        <Actions>
          <CSharp Order="-1">
            <Code>return "100".Equals(V?.Trim()) ? "Yes" : "No";</Code>
          </CSharp>
        </Actions>
      </String>

      <!-- ReferenceNumber: Acquirer reference number from Worldpay (23 chars) -->
      <String Alias="ReferenceNumber" DataField="ReferenceNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- Fee: implied 2-decimal (e.g. 090 = 0.90), only present when ChargebackType=FEE -->
      <String Alias="Fee" DataField="Fee">
        <Actions>
          <CSharp Order="-1">
            <Code>
              var s = V?.Trim();
              if (string.IsNullOrEmpty(s)) return null;
              if (long.TryParse(s, out long val))
                return (val / 100.0).ToString("F2");
              return s;
            </Code>
          </CSharp>
        </Actions>
      </String>

      <!-- EntryMode: 00=Not used, 01=Keyed, 02=MagStripe, 90=MagStripe PS2000 -->
      <String Alias="EntryMode" DataField="EntryMode">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- MerchantNumber: Merchant Identification Number (16 chars) -->
      <String Alias="MerchantNumber" DataField="MerchantNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- Segment 2/3 raw extractions — trimmed here, merged into Seg-1 record in Massage -->
      <String Alias="Seg2UserNote" DataField="Seg2UserNote">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg2CommentToMerchant" DataField="Seg2CommentToMerchant">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg2CommentFromMerchant" DataField="Seg2CommentFromMerchant">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg3ResearchComments" DataField="Seg3ResearchComments">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg5DiscretionaryField1" DataField="Seg5DiscretionaryField1">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg5DiscretionaryField2" DataField="Seg5DiscretionaryField2">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg5DiscretionaryField3" DataField="Seg5DiscretionaryField3">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg5AmazonPayChargeId" DataField="Seg5AmazonPayChargeId">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>
      <String Alias="Seg5PAR" DataField="Seg5PAR">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- MerchantChain: Chain code (5 chars) -->
      <String Alias="MerchantChain" DataField="MerchantChain">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- DivisionNumber: Merchant division (3 chars) -->
      <String Alias="DivisionNumber" DataField="DivisionNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- MerchantStoreNumber: Store number within chain (9 chars) -->
      <String Alias="MerchantStoreNumber" DataField="MerchantStoreNumber">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- ECI: Electronic Commerce Indicator -->
      <String Alias="ECI" DataField="ECI">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

      <!-- CommentsFromIssuer: Free-form issuer comments (50 chars) -->
      <String Alias="CommentsFromIssuer" DataField="CommentsFromIssuer">
        <Actions><CSharp Order="-1"><Code>return V?.Trim();</Code></CSharp></Actions>
      </String>

    </Fields>
    <!--
      GlobalVariables are class-level fields on the single Massage instance that
      is reused for every batch call. This makes _seg1Map/_supMap/_totalMap persist
      across batch boundaries — the root cause of the earlier batch-split bug.

      Flow per batch:
        1. Accumulate incoming records into _seg1Map (Seg-1) or _supMap (Seg-2+).
        2. For each RecordNumber in _seg1Map, check if received count == TotalSegments.
        3. If complete: merge _supMap entries into seg1, emit, clean up.
        4. Incomplete records stay in the maps and are re-checked on the next batch.
    -->
    <Massage GlobalVariables="Dictionary&lt;string,IDictionary&lt;string,object&gt;&gt; _seg1Map;Dictionary&lt;string,List&lt;IDictionary&lt;string,object&gt;&gt;&gt; _supMap;Dictionary&lt;string,int&gt; _totalMap;">
      <Code>
        // Initialize on first batch (fields default to null)
        if (_seg1Map == null)
        {
          _seg1Map  = new Dictionary&lt;string, IDictionary&lt;string, object&gt;&gt;();
          _supMap   = new Dictionary&lt;string, List&lt;IDictionary&lt;string, object&gt;&gt;&gt;();
          _totalMap = new Dictionary&lt;string, int&gt;();
        }

        // Accumulate this batch into the cross-batch tracking maps
        foreach (var record in B)
        {
          var recNum = record.ContainsKey("RecordNumber") ? record["RecordNumber"]?.ToString() ?? "" : "";
          var segNum = record.ContainsKey("SegmentNumber") ? record["SegmentNumber"]?.ToString() ?? "1" : "1";
          int total = 1;
          if (record.ContainsKey("TotalSegments")) int.TryParse(record["TotalSegments"]?.ToString(), out total);
          if (total &lt; 1) total = 1;

          if (!_totalMap.ContainsKey(recNum)) _totalMap[recNum] = total;

          if (segNum == "1")
            _seg1Map[recNum] = record;
          else
          {
            if (!_supMap.ContainsKey(recNum)) _supMap[recNum] = new List&lt;IDictionary&lt;string, object&gt;&gt;();
            _supMap[recNum].Add(record);
          }
        }

        // Emit records whose all segments have now arrived
        var result   = new List&lt;IDictionary&lt;string, object&gt;&gt;();
        var completed = new List&lt;string&gt;();

        foreach (var recNum in _seg1Map.Keys)
        {
          if (!_totalMap.TryGetValue(recNum, out int total)) continue;
          var supCount = _supMap.ContainsKey(recNum) ? _supMap[recNum].Count : 0;
          if (1 + supCount &lt; total) continue; // Still waiting for more segments

          var seg1 = _seg1Map[recNum];

          if (_supMap.ContainsKey(recNum))
          {
            foreach (var seg in _supMap[recNum])
            {
              var segNum = seg.ContainsKey("SegmentNumber") ? seg["SegmentNumber"]?.ToString() : null;
              if (segNum == "2")
              {
                var note = seg.ContainsKey("Seg2UserNote") ? seg["Seg2UserNote"]?.ToString() : null;
                var ctm  = seg.ContainsKey("Seg2CommentToMerchant") ? seg["Seg2CommentToMerchant"]?.ToString() : null;
                var cfm  = seg.ContainsKey("Seg2CommentFromMerchant") ? seg["Seg2CommentFromMerchant"]?.ToString() : null;
                if (!string.IsNullOrEmpty(note)) seg1["UserNote"] = note;
                if (!string.IsNullOrEmpty(ctm))  seg1["CommentToMerchant"] = ctm;
                if (!string.IsNullOrEmpty(cfm))  seg1["CommentFromMerchant"] = cfm;
              }
              else if (segNum == "3" || segNum == "4")
              {
                var rc = seg.ContainsKey("Seg3ResearchComments") ? seg["Seg3ResearchComments"]?.ToString() : null;
                if (!string.IsNullOrEmpty(rc))
                {
                  var existing = seg1.ContainsKey("ResearchComments") ? seg1["ResearchComments"]?.ToString() : null;
                  seg1["ResearchComments"] = string.IsNullOrEmpty(existing) ? rc : existing + " " + rc;
                }
              }
              else if (segNum == "5")
              {
                var df1    = seg.ContainsKey("Seg5DiscretionaryField1") ? seg["Seg5DiscretionaryField1"]?.ToString() : null;
                var df2    = seg.ContainsKey("Seg5DiscretionaryField2") ? seg["Seg5DiscretionaryField2"]?.ToString() : null;
                var df3    = seg.ContainsKey("Seg5DiscretionaryField3") ? seg["Seg5DiscretionaryField3"]?.ToString() : null;
