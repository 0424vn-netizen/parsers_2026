{

  "DataProvider": {
    "Hub-CosmosDb": null,
    "Hub-Mongo": {
      "Service": "192.168.119.107", //"localhost",
      "Port": 27017,
      "Username": "admin",
      "Password": "admin",
      "DbName": "bulk-insert"
    },
    "Hub-SqlServer": {
      "ConnectionString": "Server=DPSSERVER\\en17;Initial Catalog=TEST_MP;Integrated Security=SSPI"
      //"ConnectionString": "Server=.;Database=HubReport;User Id=sa;Password=Pass@word;"
    }
  },

  "Etl": {
    "ConfigFiles": {
      "Location": "./EtlConfigs",
      "Categories": {
        "Chargeback": {
          "Pattern": ".*_Chargebacks_.*",
          "File": "DFM_009_Chargebacks_Config.xml"
        },
        "Merchant": {
          "Pattern": "(?i:^ZASx534A\\..*).",
          "File": "MCPS_FDNORTH_MIF_Config.xml"
        },
        "Transaction": {
          "Pattern": ".*_Transactions_.*",
          "File": "DFM_003004005_Transaction_Config.xml"
        },
        "Authorization": {
          "Pattern": ".*_Authorizations_.*",
          "File": "DFM_021_Authorization_Config.xml"
        }
      },
      "IsCompare": true,
      "ThreadSleep": 3000,
      "Retry": 3
    },

    "Extraction": {
      "MaxThread": 2
    },

    "Transformation": {
      //"References": [ "./Etl.Transformation.dll" ],
      "Cryptor": {
        "CryptorFile": "E:/DLL/keys.xml",
        "HashFile": "E:/DLL/HashSaltKeys/salt.xml"
      }
    },

    "Load": {
      "MaxBatchBuffer": 10
      //"References": [ "./Etl.Storage.dll" ],
    }
  },
  "HASH_SALT_PATH": "E:/DLL/HashSaltKeys",
  "KEY_HASH_FILE_PATH": "E:/DLL/keys.xml"
}